# Application
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///storage/recipe_assistant.db
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_API_BASE_URL=http://127.0.0.1:8000
FRONTEND_USER_ID=1
FRONTEND_PORT=8501
# Optional absolute interpreter path when no venv/Conda environment is activated
PROJECT_PYTHON=

# Chat model
CHAT_ENABLED=true
CHAT_MODEL=deepseek-v4-flash
CHAT_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
CHAT_TEMPERATURE=0.2
CHAT_TIMEOUT_SECONDS=60
CHAT_MAX_RETRIES=2

# Local embedding
EMBEDDING_ENABLED=true
EMBEDDING_MODEL_PATH=model/embeddingmodels/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_OFFLINE=true

# Chroma
CHROMA_ENABLED=true
CHROMA_COLLECTION_NAME=recipe_chunks
CHROMA_PERSIST_DIR=storage/chroma_db

# BM25
BM25_ENABLED=true

# Neo4j is optional for local startup
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_CONNECT_TIMEOUT_SECONDS=10

# Optional integrations
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
MCP_ENABLED=false

# Weather
WEATHER_ENABLED=true
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT_SECONDS=8
